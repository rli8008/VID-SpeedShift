{
  "manifest_version": 3,
  "name": "VID SpeedShift",
  "version": "1.0.0",
  "description": "Control video playback speed on any website.",
  "permissions": ["activeTab"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "96": "icons/96.png",
    "128": "icons/128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "vid-speedshift@rli8008"
    }
  }
}